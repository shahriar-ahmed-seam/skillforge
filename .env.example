# SkillForge configuration — all optional.

# Where your local Ollama OpenAI-compatible endpoint lives.
OLLAMA_BASE_URL=http://localhost:11434/v1

# Which local model to use for generation.
OLLAMA_MODEL=gemma3:4b

# AI mode:
#   auto   → try Ollama, fall back to demo content if unreachable (default locally)
#   ollama → always use Ollama (fail loudly if unreachable)
#   demo   → always use built-in demo content (default on Vercel / hosted)
AI_MODE=auto
